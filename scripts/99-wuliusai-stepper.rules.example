# Copy this file to /etc/udev/rules.d/ only after replacing USB_PATH below.
# Run: udevadm info -q property -n /dev/ttyUSB0 | grep '^ID_PATH='
SUBSYSTEM=="tty", ENV{ID_BUS}=="usb", ENV{ID_VENDOR_ID}=="1a86", ENV{ID_MODEL_ID}=="7523", ENV{ID_PATH}=="REPLACE_WITH_JETSON_USB_PATH", SYMLINK+="stepper_controller", MODE="0660", GROUP="dialout"
